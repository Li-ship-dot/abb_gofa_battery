<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:include filename="$(find abb_resources)/urdf/common_materials.xacro"/>

  <!--
    ABB GoFa CRB15000-10/1.52
    - 6 DOF industrial collaborative robot
    - Payload: 10 kg
    - Reach: 1.52 m
    - Controller: OmniCore
  -->
  <xacro:macro name="abb_gofa_crb15000_10_152" params="prefix">
    <!-- link list -->
    <link name="${prefix}base_link">
      <inertial>
        <mass value="13.5"/>
        <origin xyz="-0.025 0.000 0.110"/>
        <inertia ixx="0.10" ixy="0.0005" ixz="0.0003" iyy="0.14" iyz="-0.0002" izz="0.13"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/collision/base_link.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/visual/base_link.stl"/>
        </geometry>
        <xacro:material_abb_dark_gray />
      </visual>
    </link>

    <link name="${prefix}link_1">
      <inertial>
        <mass value="11.8"/>
        <origin xyz="0.001 -0.001 -0.060"/>
        <inertia ixx="0.11" ixy="-0.00005" ixz="0.0003" iyy="0.09" iyz="-0.0001" izz="0.09"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/collision/link_1.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/visual/link_1.stl"/>
        </geometry>
        <xacro:material_abb_dark_gray />
      </visual>
    </link>

    <link name="${prefix}link_2">
      <inertial>
        <mass value="17.5"/>
        <origin xyz="-0.001 0.000 0.250"/>
        <inertia ixx="0.49" ixy="0.00001" ixz="0.0002" iyy="0.46" iyz="-0.002" izz="0.09"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/collision/link_2.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/visual/link_2.stl"/>
        </geometry>
        <xacro:material_abb_dark_gray />
      </visual>
    </link>

    <link name="${prefix}link_3">
      <inertial>
        <mass value="7.5"/>
        <origin xyz="0.100 0.001 0.032"/>
        <inertia ixx="0.025" ixy="0.0001" ixz="-0.0056" iyy="0.09" iyz="0.0001" izz="0.08"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/collision/link_3.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/visual/link_3.stl"/>
        </geometry>
        <xacro:material_abb_dark_gray />
      </visual>
    </link>

    <link name="${prefix}link_4">
      <inertial>
        <mass value="2.7"/>
        <origin xyz="0.380 0.001 0.005"/>
        <inertia ixx="0.006" ixy="-0.0001" ixz="0.0004" iyy="0.012" iyz="-0.00002" izz="0.011"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/collision/link_4.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/visual/link_4.stl"/>
        </geometry>
        <xacro:material_abb_dark_gray />
      </visual>
    </link>

    <link name="${prefix}link_5">
      <inertial>
        <mass value="0.63"/>
        <origin xyz="0.011 -0.001 0.000"/>
        <inertia ixx="0.0005" ixy="-0.00001" ixz="0.0" iyy="0.0011" iyz="0.0" izz="0.0009"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/collision/link_5.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/visual/link_5.stl"/>
        </geometry>
        <xacro:material_abb_dark_gray />
      </visual>
    </link>

    <link name="${prefix}link_6">
      <inertial>
        <mass value="0.14"/>
        <origin xyz="-0.007 0.000 0.0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/collision/link_6.stl"/>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh filename="package://abb_gofa_crb15000_support/meshes/gofa_crb15000_10_152/visual/link_6.stl"/>
        </geometry>
        <xacro:material_abb_dark_gray />
      </visual>
    </link>
    <!-- end of link list -->

    <!-- joint list -->
    <!-- GoFa CRB15000 Joint Specifications -->
    <!-- Axis 1: ±270°, 180°/s, 3850 Nm -->
    <joint type="revolute" name="${prefix}joint_1">
      <origin xyz="-0.430 -0.480 0.210" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link_1"/>
      <limit effort="0" lower="${radians(-270)}" upper="${radians(270)}" velocity="${radians(180)}"/>
      <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <!-- Axis 2: -140° to +90°, 180°/s, 3850 Nm -->
    <joint type="revolute" name="${prefix}joint_2">
      <origin xyz="0.150 0 0.290" rpy="0 0.340 0"/>
      <axis xyz="0 1 0"/>
      <parent link="${prefix}link_1"/>
      <child link="${prefix}link_2"/>
      <limit effort="0" lower="${radians(-140)}" upper="${radians(90)}" velocity="${radians(180)}"/>
      <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <!-- Axis 3: -225° to +85°, 180°/s, 2040 Nm -->
    <joint type="revolute" name="${prefix}joint_3">
      <origin xyz="0 0 0.570" rpy="0 -0.577 0"/>
      <axis xyz="0 1 0"/>
      <parent link="${prefix}link_2"/>
      <child link="${prefix}link_3"/>
      <limit effort="0" lower="${radians(-225)}" upper="${radians(85)}" velocity="${radians(180)}"/>
      <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <!-- Axis 4: ±200°, 225°/s, 1070 Nm -->
    <joint type="revolute" name="${prefix}joint_4">
      <origin xyz="0.090 0 0.040" rpy="0.145 0 0"/>
      <axis xyz="1 0 0"/>
      <parent link="${prefix}link_3"/>
      <child link="${prefix}link_4"/>
      <limit effort="0" lower="${radians(-200)}" upper="${radians(200)}" velocity="${radians(225)}"/>
      <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <!-- Axis 5: ±130°, 225°/s, 1070 Nm -->
    <joint type="revolute" name="${prefix}joint_5">
      <origin xyz="0.580 0 0" rpy="0 0.205 0"/>
      <axis xyz="0 1 0"/>
      <parent link="${prefix}link_4"/>
      <child link="${prefix}link_5"/>
      <limit effort="0" lower="${radians(-130)}" upper="${radians(130)}" velocity="${radians(225)}"/>
      <dynamics damping="2.0" friction="1.0"/>
    </joint>

    <!-- Axis 6: ±270°, 450°/s, 270 Nm -->
    <joint type="revolute" name="${prefix}joint_6">
      <origin xyz="0.078 0 0" rpy="1.429 0 0"/>
      <axis xyz="1 0 0"/>
      <parent link="${prefix}link_5"/>
      <child link="${prefix}link_6"/>
      <limit effort="0" lower="${radians(-270)}" upper="${radians(270)}" velocity="${radians(450)}"/>
      <dynamics damping="1.0" friction="1.0"/>
    </joint>
    <!-- end of joint list -->

    <!-- ROS-Industrial 'base' frame- base_link to ABB World Coordinates transform -->
    <link name="${prefix}base" />
    <joint name="${prefix}base_link-base" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}base"/>
    </joint>

    <!-- ROS-Industrial 'flange' frame- attachment point for EEF models -->
    <link name="${prefix}flange"/>
    <joint type="fixed" name="${prefix}joint_6-flange">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}link_6"/>
      <child link="${prefix}flange"/>
    </joint>

    <!-- ROS-Industrial 'tool0' frame- all-zeros tool frame -->
    <link name="${prefix}tool0" />
    <joint name="${prefix}link_6-tool0" type="fixed">
      <origin xyz="0 0 0" rpy="0 ${radians(90)} 0" />
      <parent link="${prefix}flange" />
      <child link="${prefix}tool0" />
    </joint>
  </xacro:macro>
</robot>
